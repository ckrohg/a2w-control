# a2w-hub environment variables (set these ON THE HUB / in Railway)

# Bearer token the Pi bridge presents on its WS handshake (Authorization: Bearer <token>).
HUB_PI_TOKEN=replace-with-a-long-random-secret

# Bearer token the optimizer + Vercel dashboard present on HTTP requests.
HUB_CLIENT_TOKEN=replace-with-a-different-long-random-secret

# HTTP + WS port. Railway injects PORT automatically; default is 8080 locally.
PORT=8080

# Dead-man watchdog (replaces healthchecks.io): if the Pi stops checking in, the hub pushes an
# ntfy alert. Use the SAME topic the Pi uses so all A2W alerts land in one place. Leave unset
# to disable.
NTFY_TOPIC=
# NTFY_SERVER=https://ntfy.sh        # default; override for a self-hosted ntfy
# PI_SILENCE_ALERT_MS=180000         # grace window before "Pi offline" fires (default 3 min)
