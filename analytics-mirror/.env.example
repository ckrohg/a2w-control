# Copy to .env.local for local dev; on Vercel set these as Environment Variables.

# Shared secret the Pi sends as `Authorization: Bearer <token>` to /api/ingest.
# Must match `analytics.token` in the Pi's ~/bridge-data/config.yaml.
INGEST_TOKEN=change-me-to-a-long-random-string

# Dashboard login (the human viewing the site).
VIEW_PASSWORD=your-dashboard-password
# A DIFFERENT random string — the value stored in the session cookie (never the password).
VIEW_SESSION_SECRET=another-long-random-string

# POSTGRES_URL etc. are injected automatically when you add the Vercel Postgres (Neon)
# integration to the project — you don't set these by hand.
